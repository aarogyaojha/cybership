# ==========================================
# BACKEND CONFIGURATION
# Copy the following variables to: backend/.env
# ==========================================

# UPS Authentication
UPS_CLIENT_ID=your_client_id
UPS_CLIENT_SECRET=your_client_secret
UPS_BASE_URL=https://onlinetools.ups.com
UPS_ACCOUNT_NUMBER=your_account_number

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cybership

# JWT and cookie secrets
JWT_SECRET=a_long_random_jwt_secret_min_32_characters
COOKIE_SECRET=a_long_random_cookie_secret_min_32_characters

# Cookies & Backend Server
PORT=3000
NODE_ENV=development

# ==========================================
# FRONTEND CONFIGURATION
# Copy the following variables to: frontend/.env.local
# ==========================================

# Backend URL for internal routing and Next.js proxy
BACKEND_URL=http://localhost:3000

# Public facing URL for the Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:3001
